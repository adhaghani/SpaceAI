# SimSat service endpoints
SIMSAT_CONTROL_URL=http://localhost:8000
SIMSAT_DATA_URL=http://localhost:9005

# SimSat image provider (sentinel or mapbox)
IMAGE_PROVIDER=mapbox
SPECTRAL_BANDS=swir22,nir,red
SIZE_KM=10.0
WINDOW_SECONDS=864000
IMAGE_FETCH_TIMEOUT_MS=8000
IMAGE_FETCH_RETRIES=2
IMAGE_FETCH_RETRY_DELAY_MS=250
IMAGE_FETCH_SUPPRESS_UPSTREAM_5XX=true
IMAGE_FETCH_SUPPRESS_TIMEOUT_ABORT=true

# LM Studio inference settings
LM_STUDIO_ENABLED=true
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=lfm2.5-vl-450m@q4_0
LM_STUDIO_TIMEOUT_SECONDS=40
FIRE_MIN_CONFIDENCE=0.7
FIRE_MAPBOX_MIN_CONFIDENCE=0.88
FIRE_ALLOW_LOW_SEVERITY=false
FIRE_LOW_SEVERITY_OVERRIDE_CONFIDENCE=0.95

# Optional auth tokens (either key works)
LM_API_TOKEN=
LM_STUDIO_API_KEY=
